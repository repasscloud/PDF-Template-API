{
  "template": {
    "title": "",
    "pageSize": "A4",
    "orientation": "Landscape",
    "margin": 40,
    "defaultFontSize": 11,
    "blockSpacing": 6,
    "showPageNumbers": false,
    "blocks": [
      {
        "type": "image",
        "dataPath": "logoBase64",
        "width": 80,
        "height": 44,
        "align": "left"
      },
      {
        "type": "spacer",
        "height": 10
      },
      {
        "type": "heading",
        "level": 1,
        "text": "{{certificateTitle}}",
        "fontSize": 26
      },
      {
        "type": "spacer",
        "height": 20
      },
      {
        "type": "text",
        "text": "Awarded to",
        "fontSize": 10
      },
      {
        "type": "text",
        "text": "{{recipientName}}",
        "bold": true,
        "fontSize": 38
      },
      {
        "type": "spacer",
        "height": 10
      },
      {
        "type": "text",
        "text": "For completing",
        "fontSize": 10
      },
      {
        "type": "text",
        "text": "{{courseName}}",
        "bold": true,
        "fontSize": 20
      },
      {
        "type": "spacer",
        "height": 18
      },
      {
        "type": "line"
      },
      {
        "type": "spacer",
        "height": 10
      },
      {
        "type": "twoColumn",
        "gap": 24,
        "leftWidth": 2,
        "rightWidth": 1,
        "leftBlocks": [
          {
            "type": "text",
            "text": "Completed: {{completionDate}}",
            "fontSize": 10
          },
          {
            "type": "text",
            "text": "Issued by: {{issuedBy}}",
            "fontSize": 10
          },
          {
            "type": "text",
            "text": "Valid until: {{validUntil}}",
            "fontSize": 10
          },
          {
            "type": "spacer",
            "height": 6
          },
          {
            "type": "text",
            "text": "Certificate ID: {{certificateId}}",
            "fontSize": 8
          },
          {
            "type": "spacer",
            "height": 14
          },
          {
            "type": "signature",
            "label": "{{issuerTitle}}",
            "value": "{{issuerName}}",
            "caption": "{{issuedBy}}",
            "width": 200,
            "height": 32
          }
        ],
        "rightBlocks": [
          {
            "type": "qrCode",
            "value": "{{qrCodeValue}}",
            "size": 100,
            "caption": "Scan to verify",
            "align": "right"
          }
        ]
      }
    ]
  },
  "data": {
    "logoBase64": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO+/p9sAAAAASUVORK5CYII=",
    "certificateTitle": "Certificate of Completion",
    "recipientName": "Jane Smith",
    "courseName": "Cyber Security Awareness Training",
    "completionDate": "30 June 2026",
    "issuedBy": "RePass Cloud Pty Ltd",
    "certificateId": "CERT-2026-000123",
    "issuerName": "Danijel Wynyard",
    "issuerTitle": "Director",
    "validUntil": "30 June 2028",
    "notes": "Completed all required modules and assessments.",
    "qrCodeValue": "https://example.com/verify/CERT-2026-000123"
  },
  "output": {
    "fileName": "certificate-modern-corporate.pdf"
  }
}
