{
  "title": "",
  "pageSize": "A4",
  "orientation": "Portrait",
  "margin": 40,
  "defaultFontSize": 10,
  "blockSpacing": 6,
  "showPageNumbers": true,
  "blocks": [
    {
      "type": "watermark",
      "text": "{{report.status}}",
      "fontSize": 70,
      "color": "#F3F4F6"
    },
    {
      "type": "twoColumn",
      "gap": 20,
      "leftWidth": 1,
      "rightWidth": 1,
      "leftBlocks": [
        {
          "type": "heading",
          "level": 1,
          "text": "Service Report",
          "fontSize": 22
        },
        {
          "type": "text",
          "text": "{{report.number}}",
          "bold": true,
          "fontSize": 13
        },
        {
          "type": "spacer",
          "height": 14
        },
        {
          "type": "image",
          "base64": "{{company.logoBase64}}",
          "width": 80,
          "height": 36,
          "align": "left"
        },
        {
          "type": "spacer",
          "height": 4
        },
        {
          "type": "addressBlock",
          "label": "{{company.name}}",
          "lines": [
            "{{company.email}}",
            "{{company.phone}}"
          ]
        }
      ],
      "rightBlocks": [
        {
          "type": "barcode",
          "value": "{{job.number}}",
          "width": 220,
          "height": 48,
          "caption": "Job {{job.number}}",
          "align": "right"
        },
        {
          "type": "text",
          "text": "Date: {{report.date}}",
          "align": "right"
        },
        {
          "type": "text",
          "text": "Technician: {{technician.name}}",
          "align": "right"
        },
        {
          "type": "spacer",
          "height": 14
        },
        {
          "type": "addressBlock",
          "label": "Client",
          "lines": [
            "{{client.name}}",
            "{{client.site}}",
            "{{client.address.line1}}",
            "{{client.address.city}} {{client.address.state}} {{client.address.postcode}}"
          ]
        }
      ]
    },
    {
      "type": "spacer",
      "height": 12
    },
    {
      "type": "line"
    },
    {
      "type": "spacer",
      "height": 8
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Work Performed"
    },
    {
      "type": "table",
      "dataPath": "workItems",
      "showHeader": true,
      "columns": [
        {
          "header": "Task",
          "value": "{{task}}"
        },
        {
          "header": "Result",
          "value": "{{result}}",
          "width": 120
        },
        {
          "header": "Time",
          "value": "{{time}}",
          "width": 70,
          "align": "right"
        }
      ]
    },
    {
      "type": "spacer",
      "height": 10
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Parts Used"
    },
    {
      "type": "table",
      "dataPath": "parts",
      "showHeader": true,
      "columns": [
        {
          "header": "Part",
          "value": "{{name}}"
        },
        {
          "header": "Qty",
          "value": "{{quantity}}",
          "width": 50,
          "align": "right"
        },
        {
          "header": "Notes",
          "value": "{{notes}}"
        }
      ]
    },
    {
      "type": "spacer",
      "height": 12
    },
    {
      "type": "termsAndConditions",
      "label": "Technician Notes",
      "lines": [
        "{{report.notes.line1}}",
        "{{report.notes.line2}}"
      ]
    },
    {
      "type": "spacer",
      "height": 14
    },
    {
      "type": "twoColumn",
      "gap": 20,
      "leftBlocks": [
        {
          "type": "signature",
          "label": "Technician Signature",
          "value": "{{technician.name}}",
          "caption": "Date: {{report.date}}",
          "width": 220,
          "height": 40
        }
      ],
      "rightBlocks": [
        {
          "type": "signature",
          "label": "Client Acceptance",
          "value": "{{client.contact}}",
          "caption": "Date:",
          "width": 220,
          "height": 40,
          "align": "right"
        }
      ]
    }
  ]
}
