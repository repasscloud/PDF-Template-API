{
  "title": "",
  "pageSize": "A4",
  "orientation": "Portrait",
  "margin": 40,
  "defaultFontSize": 10,
  "blockSpacing": 6,
  "showPageNumbers": true,
  "blocks": [
    {
      "type": "watermark",
      "text": "{{delivery.status}}",
      "fontSize": 70,
      "color": "#F3F4F6"
    },
    {
      "type": "twoColumn",
      "gap": 20,
      "leftWidth": 1,
      "rightWidth": 1,
      "leftBlocks": [
        {
          "type": "heading",
          "level": 1,
          "text": "Delivery Docket",
          "fontSize": 20
        },
        {
          "type": "text",
          "text": "{{delivery.number}}",
          "bold": true,
          "fontSize": 13
        },
        {
          "type": "spacer",
          "height": 14
        },
        {
          "type": "image",
          "base64": "{{company.logoBase64}}",
          "width": 80,
          "height": 36,
          "align": "left"
        },
        {
          "type": "spacer",
          "height": 4
        },
        {
          "type": "addressBlock",
          "label": "{{company.name}}",
          "lines": [
            "{{company.email}}",
            "{{company.phone}}"
          ]
        }
      ],
      "rightBlocks": [
        {
          "type": "barcode",
          "value": "{{delivery.number}}",
          "width": 220,
          "height": 48,
          "align": "right"
        },
        {
          "type": "text",
          "text": "Delivery Date: {{delivery.date}}",
          "align": "right"
        },
        {
          "type": "text",
          "text": "Carrier: {{delivery.carrier}}",
          "align": "right"
        },
        {
          "type": "text",
          "text": "Tracking: {{delivery.trackingNumber}}",
          "align": "right"
        },
        {
          "type": "spacer",
          "height": 14
        },
        {
          "type": "addressBlock",
          "label": "Deliver To",
          "lines": [
            "{{recipient.name}}",
            "{{recipient.contact}}",
            "{{recipient.address.line1}}",
            "{{recipient.address.city}} {{recipient.address.state}} {{recipient.address.postcode}}"
          ]
        }
      ]
    },
    {
      "type": "spacer",
      "height": 12
    },
    {
      "type": "line"
    },
    {
      "type": "spacer",
      "height": 8
    },
    {
      "type": "table",
      "dataPath": "packages",
      "showHeader": true,
      "columns": [
        {
          "header": "Item",
          "value": "{{item}}"
        },
        {
          "header": "SKU",
          "value": "{{sku}}",
          "width": 90
        },
        {
          "header": "Qty",
          "value": "{{quantity}}",
          "width": 50,
          "align": "right"
        },
        {
          "header": "Notes",
          "value": "{{notes}}"
        }
      ]
    },
    {
      "type": "spacer",
      "height": 14
    },
    {
      "type": "twoColumn",
      "gap": 20,
      "leftBlocks": [
        {
          "type": "signature",
          "label": "Driver Signature",
          "value": "{{driver.name}}",
          "caption": "Date: {{delivery.date}}",
          "width": 220,
          "height": 40
        }
      ],
      "rightBlocks": [
        {
          "type": "signature",
          "label": "Received By",
          "value": "{{recipient.contact}}",
          "caption": "Date:",
          "width": 220,
          "height": 40,
          "align": "right"
        }
      ]
    },
    {
      "type": "spacer",
      "height": 12
    },
    {
      "type": "twoColumn",
      "gap": 20,
      "leftWidth": 3,
      "rightWidth": 2,
      "leftBlocks": [
        {
          "type": "termsAndConditions",
          "label": "Delivery Notes",
          "lines": [
            "Receiver should inspect goods before signing.",
            "Report missing or damaged items within 24 hours.",
            "This docket is not a tax invoice."
          ]
        }
      ],
      "rightBlocks": [
        {
          "type": "qrCode",
          "value": "{{delivery.trackingUrl}}",
          "size": 70,
          "caption": "Track delivery",
          "align": "right"
        }
      ]
    }
  ]
}
