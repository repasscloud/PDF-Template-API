{
  "title": "",
  "pageSize": "A4",
  "orientation": "Landscape",
  "margin": 40,
  "defaultFontSize": 12,
  "blockSpacing": 8,
  "showPageNumbers": false,
  "blocks": [
    {
      "type": "watermark",
      "text": "{{certificate.watermark}}",
      "fontSize": 78,
      "color": "#F3F4F6"
    },
    {
      "type": "image",
      "base64": "{{company.logoBase64}}",
      "width": 80,
      "height": 50,
      "align": "center"
    },
    {
      "type": "spacer",
      "height": 4
    },
    {
      "type": "certificateTitle",
      "text": "{{certificate.title}}",
      "caption": "{{certificate.subtitle}}",
      "fontSize": 36
    },
    {
      "type": "spacer",
      "height": 50
    },
    {
      "type": "text",
      "text": "This certifies that",
      "align": "center",
      "fontSize": 13
    },
    {
      "type": "text",
      "text": "{{recipient.name}}",
      "align": "center",
      "bold": true,
      "fontSize": 28
    },
    {
      "type": "text",
      "text": "has successfully completed",
      "align": "center",
      "fontSize": 13
    },
    {
      "type": "text",
      "text": "{{course.name}}",
      "align": "center",
      "bold": true,
      "fontSize": 20
    },
    {
      "type": "spacer",
      "height": 50
    },
    {
      "type": "twoColumn",
      "gap": 50,
      "leftWidth": 1,
      "rightWidth": 1,
      "leftBlocks": [
        {
          "type": "signature",
          "label": "Authorised Signature",
          "value": "{{issuer.name}}",
          "caption": "{{issuer.title}}",
          "width": 240,
          "height": 40,
          "align": "center"
        }
      ],
      "rightBlocks": [
        {
          "type": "qrCode",
          "value": "{{certificate.verifyUrl}}",
          "size": 80,
          "caption": "Verify certificate",
          "align": "center"
        }
      ]
    },
    {
      "type": "spacer",
      "height": 8
    },
    {
      "type": "text",
      "text": "Certificate No: {{certificate.number}}  ·  Issued: {{certificate.issueDate}}",
      "align": "center",
      "fontSize": 9
    }
  ]
}
