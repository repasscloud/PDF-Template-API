{
  "title": "",
  "pageSize": "A4",
  "orientation": "Portrait",
  "margin": 40,
  "defaultFontSize": 10,
  "blockSpacing": 6,
  "showPageNumbers": true,
  "blocks": [
    {
      "type": "watermark",
      "text": "PAID",
      "fontSize": 76,
      "color": "#E8F5E9"
    },
    {
      "type": "twoColumn",
      "gap": 20,
      "leftWidth": 1,
      "rightWidth": 1,
      "leftBlocks": [
        {
          "type": "heading",
          "level": 1,
          "text": "Payment Receipt",
          "fontSize": 20
        },
        {
          "type": "text",
          "text": "{{receipt.number}}",
          "bold": true,
          "fontSize": 13
        },
        {
          "type": "text",
          "text": "Date: {{payment.paidAt}}"
        },
        {
          "type": "text",
          "text": "Original Invoice: {{invoice.number}}"
        },
        {
          "type": "text",
          "text": "Payment Reference: {{payment.reference}}"
        }
      ],
      "rightBlocks": [
        {
          "type": "barcode",
          "value": "{{receipt.number}}",
          "width": 220,
          "height": 48,
          "caption": "{{receipt.number}}",
          "align": "right"
        }
      ]
    },
    {
      "type": "spacer",
      "height": 4
    },
    {
      "type": "twoColumn",
      "gap": 20,
      "leftWidth": 1,
      "rightWidth": 1,
      "leftBlocks": [
        {
          "type": "image",
          "base64": "{{company.logoBase64}}",
          "width": 80,
          "height": 20,
          "align": "left"
        },
        {
          "type": "spacer",
          "height": 4
        },
        {
          "type": "addressBlock",
          "label": "{{company.name}}",
          "lines": [
            "{{company.email}}",
            "{{company.abn}}"
          ]
        }
      ],
      "rightBlocks": [
        {
          "type": "spacer",
          "height": 24
        },
        {
          "type": "addressBlock",
          "label": "Received From",
          "lines": [
            "{{customer.name}}",
            "{{customer.email}}"
          ]
        }
      ]
    },
    {
      "type": "spacer",
      "height": 12
    },
    {
      "type": "line"
    },
    {
      "type": "spacer",
      "height": 8
    },
    {
      "type": "table",
      "dataPath": "payments",
      "showHeader": true,
      "columns": [
        {
          "header": "Description",
          "value": "{{description}}"
        },
        {
          "header": "Date",
          "value": "{{date}}",
          "width": 90
        },
        {
          "header": "Amount",
          "value": "{{amount}}",
          "width": 90,
          "align": "right"
        }
      ]
    },
    {
      "type": "spacer",
      "height": 10
    },
    {
      "type": "totalsBox",
      "align": "right",
      "width": 230,
      "padding": 10,
      "keyValues": [
        {
          "label": "Amount Paid",
          "value": "{{totals.amountPaid}}",
          "bold": true,
          "fontSize": 13
        },
        {
          "label": "Balance Due",
          "value": "{{totals.balanceDue}}"
        }
      ]
    },
    {
      "type": "spacer",
      "height": 12
    },
    {
      "type": "twoColumn",
      "gap": 20,
      "leftWidth": 3,
      "rightWidth": 2,
      "leftBlocks": [
        {
          "type": "termsAndConditions",
          "label": "Receipt Notes",
          "lines": [
            "This receipt confirms payment received against invoice {{invoice.number}}.",
            "Please retain this document for your records."
          ]
        }
      ],
      "rightBlocks": [
        {
          "type": "qrCode",
          "value": "{{receipt.verifyUrl}}",
          "size": 70,
          "caption": "Verify receipt",
          "align": "right"
        }
      ]
    }
  ]
}
