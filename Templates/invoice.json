{
  "title": "",
  "pageSize": "A4",
  "orientation": "Portrait",
  "margin": 40,
  "defaultFontSize": 10,
  "blockSpacing": 6,
  "showPageNumbers": true,
  "blocks": [
    {
      "type": "twoColumn",
      "gap": 24,
      "leftWidth": 3,
      "rightWidth": 2,
      "leftBlocks": [
        {
          "type": "heading",
          "level": 1,
          "text": "Tax Invoice"
        },
        {
          "type": "text",
          "text": "{{invoice.number}}",
          "bold": true,
          "fontSize": 12
        },
        {
          "type": "spacer",
          "height": 10
        },
        {
          "type": "text",
          "text": "Date: {{invoice.date}}"
        }
      ],
      "rightBlocks": [
        {
          "type": "addressBlock",
          "label": "Bill To",
          "lines": [
            "{{customer.name}}",
            "{{customer.email}}"
          ]
        }
      ]
    },
    {
      "type": "spacer",
      "height": 18
    },
    {
      "type": "line"
    },
    {
      "type": "spacer",
      "height": 12
    },
    {
      "type": "table",
      "dataPath": "items",
      "showHeader": true,
      "columns": [
        {
          "header": "Description",
          "value": "{{description}}"
        },
        {
          "header": "Qty",
          "value": "{{quantity}}",
          "width": 50,
          "align": "right"
        },
        {
          "header": "Unit Price",
          "value": "{{unitPrice}}",
          "width": 80,
          "align": "right"
        },
        {
          "header": "Total",
          "value": "{{total}}",
          "width": 80,
          "align": "right"
        }
      ]
    },
    {
      "type": "spacer",
      "height": 14
    },
    {
      "type": "totalsBox",
      "align": "right",
      "width": 240,
      "padding": 10,
      "keyValues": [
        {
          "label": "Subtotal",
          "value": "{{totals.subtotal}}"
        },
        {
          "label": "GST (10%)",
          "value": "{{totals.gst}}"
        },
        {
          "label": "Total Due",
          "value": "{{totals.total}}",
          "bold": true,
          "fontSize": 13
        }
      ]
    },
    {
      "type": "spacer",
      "height": 24
    },
    {
      "type": "termsAndConditions",
      "label": "Payment Terms",
      "lines": [
        "Payment is due within 14 days of this invoice date.",
        "All prices are in AUD and include GST where applicable.",
        "Please reference {{invoice.number}} on your payment."
      ]
    }
  ]
}
